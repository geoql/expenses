{
  "compilerOptions": {
    "target": "es2018",
    "module": "esnext",
    "moduleResolution": "node",
    "lib": [
      "esnext",
      "esnext.asynciterable",
      "dom"
    ],
    "esModuleInterop": true,
    "allowJs": true,
    "sourceMap": true,
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "~/*": [
        "./*"
      ],
      "@/*": [
        "./*"
      ]
    },
    "types": [
      "@types/node",
      "@nuxt/types",
      "@types/geojson",
      "@types/mapbox-gl",
      "@nuxtjs/axios"
    ]
  },
  "include": [
    "@types/modules/**/*.ts",
    "components/**/*.vue",
    "config/**/*.{ts,js}",
    "layouts/**/*.vue",
    "pages/**/*.vue",
    "plugins/**/*.{js,ts}",
    "utils/**/*.js",
    "nuxt.config.js",
    // TypeScript
    "plugins/**/*.ts",
    "nuxt.config.ts"
  ],
  "exclude": [
    "node_modules",
    ".nuxt",
    "dist",
    "static"
  ]
}
